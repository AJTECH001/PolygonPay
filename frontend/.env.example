# ── Wallet Connect ────────────────────────────────────────────────────────────
# Create a free project at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# ── Polygon Amoy RPC ──────────────────────────────────────────────────────────
# Public endpoint (no key needed), or use Alchemy/Infura for higher limits
NEXT_PUBLIC_POLYGON_AMOY_RPC=https://rpc-amoy.polygon.technology/

# ── Deployed Contract ─────────────────────────────────────────────────────────
# Fill this after running: forge script script/Deploy.s.sol --broadcast
NEXT_PUBLIC_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# ── Claude AI (server-side only — never expose to client) ─────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your_key_here
